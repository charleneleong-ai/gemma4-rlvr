# W&B run-local mirrors (synced to wandb.ai; no need in git)
wandb/

# Synthetic dataset artefacts — regeneratable via dd_explainer_data_generator.py.
# The sidecar .meta.json files ARE committed (small, capture provenance).
data/dd_dataset_*.jsonl

# Production LangSmith trace exports — raw parquet is heavy and uninteresting
# to re-ship; keep the scrubbed reports/metadata/refinements visible.
.error_analysis_cache/**/*.parquet

# Saved LoRA adapter directories — re-trainable, large.
# `gemma_4_lora/` = canonical (most recent run); `exp_<N>/` = per-experiment
# snapshots so retrospective eval is possible.
gemma_4_lora/

# Per-task experiment runtime artefacts (regenerated by autoresearch loop).
# The Python tracker code (experiments/*.py) IS committed.
experiments/*/results.jsonl
experiments/*/progress.html
experiments/*/progress.png
experiments/*/current_run.json
experiments/*/eval_progress.html
