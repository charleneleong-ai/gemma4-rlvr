# Copy to .env (gitignored) and fill in your values. `python -m dotenv` or
# `from dotenv import load_dotenv; load_dotenv()` will pick these up.

# ---------------------------------------------------------------------------
# Hugging Face — for gated / large model downloads and the hf_transfer speedup.
# ---------------------------------------------------------------------------
HF_TOKEN=""
HF_HUB_ENABLE_HF_TRANSFER="1"

# ---------------------------------------------------------------------------
# Weights & Biases — training metric logging.
# Both the CLI (`train.py train --config-name ...`) and the notebook read
# these via `config/base.py:WandbSettings`.
# ---------------------------------------------------------------------------
WANDB_API_KEY=""
WANDB_ENTITY="chaleong"       # wandb username or team
WANDB_PROJECT="gemma4-rlvr"
WANDB_MODE="online"           # "online" | "offline" | "disabled"

# ---------------------------------------------------------------------------
# Google Cloud (reserved — not used by the mock today; here for parity with
# the production direct_debit_explainer which hits gemini-2.5-pro on GCP).
# ---------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=""
GCP_PROJECT=""
GCP_LOCATION="europe-west1"
